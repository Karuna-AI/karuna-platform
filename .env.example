# Karuna Mobile App Environment Configuration
# Copy this file to .env for local development

# =============================================================================
# Server Configuration
# =============================================================================

# Gateway server URL (default: http://localhost:3021)
# For production, set this to your deployed server URL
GATEWAY_URL=http://localhost:3021

# =============================================================================
# API Keys (Optional)
# =============================================================================

# OpenAI API key for on-device AI features (optional)
# If not set, the app will use the server's API key
OPENAI_API_KEY=

# Metrics endpoint secret (required to access /metrics in production)
METRICS_SECRET=

# Vault field encryption key — 32-byte hex (64 hex chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=

# Base URL for the caregiver portal (used to build email verification links)
APP_BASE_URL=http://localhost:3020

# Data archival retention periods (days). Defaults shown.
ARCHIVE_HEALTH_DAYS=365
ARCHIVE_DOSE_DAYS=365
ARCHIVE_ACTIVITY_DAYS=90
ARCHIVE_CHECKIN_DAYS=90

# OpenWeatherMap API key for real weather data (optional)
# Get a free API key at: https://openweathermap.org/api
# If not set, the app will use simulated weather data
OPENWEATHER_API_KEY=

# =============================================================================
# Expo / EAS Configuration
# =============================================================================

# Expo account username (required for EAS builds)
EXPO_OWNER=your-expo-username

# EAS Project ID (set this after running `eas init`)
EAS_PROJECT_ID=your-project-id

# App environment: development, preview, or production
APP_ENV=development

# Preview API URL (for preview builds)
PREVIEW_API_URL=https://preview-api.karuna.app

# Production API URL (for production builds)
API_URL=https://api.karuna.app
