# Karuna Platform - Production Environment Configuration
# Copy this file to .env and fill in all values before deployment
#
# IMPORTANT: Never commit the actual .env file to version control!

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL credentials
DB_HOST=postgres
DB_PORT=5432
DB_NAME=karuna
DB_USER=karuna
DB_PASSWORD=<generate-secure-password-here>

# =============================================================================
# Security Configuration
# =============================================================================

# JWT secrets (generate with: openssl rand -hex 64)
JWT_SECRET=<generate-64-char-hex-string>
ADMIN_JWT_SECRET=<generate-64-char-hex-string>

# Metrics endpoint protection key (generate with: openssl rand -hex 32)
METRICS_SECRET=<generate-32-char-hex-string>

# =============================================================================
# AI Configuration
# =============================================================================

# OpenAI API key (required)
OPENAI_API_KEY=<your-openai-api-key>

# OpenRouter API key (optional, for fallback)
OPENROUTER_API_KEY=

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated for multiple)
CORS_ORIGIN=https://portal.karuna.app,https://admin.karuna.app

# =============================================================================
# Domain Configuration
# =============================================================================

# Your domain names
API_DOMAIN=api.karuna.app
PORTAL_DOMAIN=portal.karuna.app
ADMIN_DOMAIN=admin.karuna.app

# SSL email for Let's Encrypt
SSL_EMAIL=admin@karuna.app

# =============================================================================
# Expo / Mobile App Configuration
# =============================================================================

# Expo account username
EXPO_OWNER=your-expo-username

# EAS Project ID (set after running `eas init`)
EAS_PROJECT_ID=

# App environment
APP_ENV=production

# Production API URL for mobile app
API_URL=https://api.karuna.app

# =============================================================================
# Email Configuration
# =============================================================================

# Resend API key for transactional emails
RESEND_API_KEY=<your-resend-api-key>
FROM_EMAIL=Karuna <noreply@karunaapp.in>

# =============================================================================
# Scaling (Redis, optional)
# =============================================================================

# Redis URL for multi-instance gateway deployments. Enables cross-instance
# WebSocket broadcasts, a shared WS-ticket store, and a leader lock for the
# archival job. Leave unset when running a single gateway instance.
# Example: redis://default:password@host:6379
REDIS_URL=

# =============================================================================
# Error Reporting (Sentry)
# =============================================================================

# Sentry DSN for the API server (Node.js)
SENTRY_DSN=

# Sentry DSN for the caregiver portal (baked into Vite build at deploy time)
VITE_SENTRY_DSN_CAREGIVER=

# Sentry DSN for the admin portal (baked into Vite build at deploy time)
VITE_SENTRY_DSN_ADMIN=

# =============================================================================
# Optional Configuration
# =============================================================================

# Node environment
NODE_ENV=production

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable maintenance mode (true/false)
MAINTENANCE_MODE=false
