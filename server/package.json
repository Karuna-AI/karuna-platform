{
  "name": "karuna-gateway",
  "version": "1.0.0",
  "description": "AI Gateway server for Karuna - secure proxy for OpenAI APIs and Care Circle",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "eslint . --ext .js",
    "seed:admin": "node scripts/seed-admin.js",
    "db:migrate": "node db/migrations/run.js",
    "db:init": "psql -d karuna -f db/init.sql",
    "db:admin": "psql -d karuna -f db/admin_tables.sql"
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.17.2",
    "resend": "6.12.3",
    "ws": "^8.16.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "nodemon": "^3.0.2"
  }
}
