{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "distribution": "store",
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote",
        "withoutCredentials": true
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "local"
      },
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "admin@karunaapp.in",
        "ascAppId": "6760266687",
        "appleTeamId": "9K4Q978949"
      }
    },
    "production": {
      "ios": {
        "appleId": "admin@karunaapp.in",
        "ascAppId": "6760266687",
        "appleTeamId": "9K4Q978949"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
